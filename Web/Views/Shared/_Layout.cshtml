<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - One Stack POS</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
          rel="stylesheet" />

    <style>
        body {
            background-color: #f8f9fa;
        }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            background-color: #212529;
        }

        .sidebar .brand {
            height: 70px;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }

        .sidebar .nav-link {
            color: rgba(255,255,255,.8);
            padding: 12px 20px;
            border-radius: 8px;
            margin: 4px 12px;
        }

        .sidebar .nav-link:hover {
            background-color: rgba(255,255,255,.08);
            color: #fff;
        }

        .sidebar .nav-link.active {
            background-color: #0d6efd;
            color: #fff;
        }

        .sidebar .nav-link i {
            margin-right: 10px;
        }

        .content-wrapper {
            min-height: 100vh;
        }

        .top-navbar {
            height: 70px;
            background-color: #fff;
            border-bottom: 1px solid #dee2e6;
        }

        .page-content {
            padding: 24px;
        }

        .logo-circle {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #0d6efd;
            color: white;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        @@media (max-width: 991.98px) {
            .sidebar-desktop {
                display: none !important;
            }
        }

        @@media (min-width: 992px) {
            .mobile-sidebar-button {
                display: none;
            }

            .offcanvas-lg {
                visibility: visible !important;
            }
        }
    </style>

    @RenderSection("Styles", required: false)

</head>
<body>

    <div class="d-flex">

        <!-- Desktop Sidebar -->
        <aside class="sidebar sidebar-desktop d-flex flex-column flex-shrink-0">

            <!-- Brand -->
            <div class="brand d-flex align-items-center px-3">

                <div class="logo-circle me-3">
                    OS
                </div>

                <div>
                    <div class="text-white fw-bold">
                        One Stack POS
                    </div>

                    <small class="text-secondary">
                        MVP v1.0
                    </small>
                </div>

            </div>

            <!-- Menu -->
            <nav class="nav flex-column py-3">

                <a class="nav-link active" href="#">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard
                </a>

                <a class="nav-link" href="#">
                    <i class="bi bi-box-seam"></i>
                    Products
                </a>

                <a class="nav-link" href="#">
                    <i class="bi bi-tags"></i>
                    Categories
                </a>

                <a class="nav-link" href="#">
                    <i class="bi bi-people"></i>
                    Customers
                </a>

                <a class="nav-link" href="#">
                    <i class="bi bi-truck"></i>
                    Suppliers
                </a>

                <a class="nav-link" href="#">
                    <i class="bi bi-cart3"></i>
                    Sales
                </a>

                <a class="nav-link" href="#">
                    <i class="bi bi-box-arrow-in-down"></i>
                    Inventory
                </a>

                <a class="nav-link" href="#">
                    <i class="bi bi-graph-up-arrow"></i>
                    Reports
                </a>

            </nav>

            <!-- Logout -->
            <div class="mt-auto p-3">

                <a class="nav-link text-danger" href="#">
                    <i class="bi bi-box-arrow-right"></i>
                    Logout
                </a>

            </div>

        </aside>

        <!-- Main Content -->
        <div class="flex-grow-1 content-wrapper">

            <!-- Top Navbar -->
            <nav class="top-navbar navbar navbar-expand navbar-light px-3">

                <!-- Mobile Menu -->
                <button class="btn btn-outline-secondary mobile-sidebar-button"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#mobileSidebar">

                    <i class="bi bi-list fs-4"></i>

                </button>

                <div class="ms-2 fw-semibold fs-5">
                    @ViewData["PageTitle"]
                </div>

                <div class="ms-auto dropdown">

                    <button class="btn btn-light dropdown-toggle"
                            data-bs-toggle="dropdown">

                        <i class="bi bi-person-circle me-1"></i>
                        Admin

                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">

                        <li>
                            <a class="dropdown-item" href="#">
                                <i class="bi bi-person me-2"></i>
                                Profile
                            </a>
                        </li>

                        <li>
                            <hr class="dropdown-divider" />
                        </li>

                        <li>
                            <a class="dropdown-item text-danger" href="#">
                                <i class="bi bi-box-arrow-right me-2"></i>
                                Logout
                            </a>
                        </li>

                    </ul>

                </div>

            </nav>

            <!-- Page Content -->
            <main class="page-content">

                @RenderBody()

            </main>

        </div>

    </div>

    <!-- Mobile Sidebar -->
    <div class="offcanvas offcanvas-start"
         tabindex="-1"
         id="mobileSidebar">

        <div class="offcanvas-header">

            <h5 class="offcanvas-title">

                One Stack POS

            </h5>

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="offcanvas">
            </button>

        </div>

        <div class="offcanvas-body p-0">

            <nav class="nav flex-column py-3">

                <a class="nav-link px-4" href="#">
                    <i class="bi bi-speedometer2 me-2"></i>
                    Dashboard
                </a>

                <a class="nav-link px-4" href="#">
                    <i class="bi bi-box-seam me-2"></i>
                    Products
                </a>

                <a class="nav-link px-4" href="#">
                    <i class="bi bi-tags me-2"></i>
                    Categories
                </a>

                <a class="nav-link px-4" href="#">
                    <i class="bi bi-people me-2"></i>
                    Customers
                </a>

                <a class="nav-link px-4" href="#">
                    <i class="bi bi-truck me-2"></i>
                    Suppliers
                </a>

                <a class="nav-link px-4" href="#">
                    <i class="bi bi-cart3 me-2"></i>
                    Sales
                </a>

                <a class="nav-link px-4" href="#">
                    <i class="bi bi-box-arrow-in-down me-2"></i>
                    Inventory
                </a>

                <a class="nav-link px-4" href="#">
                    <i class="bi bi-graph-up-arrow me-2"></i>
                    Reports
                </a>

                <hr />

                <a class="nav-link px-4 text-danger" href="#">
                    <i class="bi bi-box-arrow-right me-2"></i>
                    Logout
                </a>

            </nav>

        </div>

    </div>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>