@{
    ViewData["Title"] = "Customers";
    ViewData["PageTitle"] = "Customer Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card border-0 shadow-sm">

    <div class="card-header bg-white">

        <div class="d-flex justify-content-between align-items-center">

            <h5 class="mb-0">
                Customer List
            </h5>

            <button class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addCustomerModal">

                <i class="bi bi-plus-circle me-1"></i>

                Add Customer

            </button>

        </div>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table id="customersTable"
                   class="table table-striped table-hover align-middle">

                <thead>

                    <tr>

                        <th>Code</th>
                        <th>Customer Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>City</th>
                        <th>Member Type</th>
                        <th>Status</th>
                        <th width="150">Action</th>

                    </tr>

                </thead>

                <tbody>

                    <tr>

                        <td>CUS001</td>
                        <td>Hendi Dwi Purwanto</td>
                        <td>081234567890</td>
                        <td>hendi@mail.com</td>
                        <td>Pasuruan</td>

                        <td>
                            <span class="badge bg-primary">
                                Gold
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-success">
                                Active
                            </span>
                        </td>

                        <td>

                            <button class="btn btn-sm btn-warning"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editCustomerModal">

                                <i class="bi bi-pencil-square"></i>

                            </button>

                            <button class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deactivateCustomerModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>CUS002</td>
                        <td>Firda</td>
                        <td>081111111111</td>
                        <td>firda@mail.com</td>
                        <td>Pasuruan</td>

                        <td>
                            <span class="badge bg-secondary">
                                Regular
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-success">
                                Active
                            </span>
                        </td>

                        <td>

                            <button class="btn btn-sm btn-warning"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editCustomerModal">

                                <i class="bi bi-pencil-square"></i>

                            </button>

                            <button class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deactivateCustomerModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>CUS003</td>
                        <td>Budi Santoso</td>
                        <td>082222222222</td>
                        <td>budi@mail.com</td>
                        <td>Surabaya</td>

                        <td>
                            <span class="badge bg-warning text-dark">
                                Silver
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-danger">
                                Inactive
                            </span>
                        </td>

                        <td>

                            <button class="btn btn-sm btn-warning"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editCustomerModal">

                                <i class="bi bi-pencil-square"></i>

                            </button>

                            <button class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deactivateCustomerModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- ADD CUSTOMER -->

<div class="modal fade"
     id="addCustomerModal"
     tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Add Customer
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="row">

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">
                                Customer Code
                            </label>

                            <input type="text"
                                   class="form-control"
                                   placeholder="CUS004" />

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">
                                Customer Name
                            </label>

                            <input type="text"
                                   class="form-control" />

                        </div>

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">
                                Phone
                            </label>

                            <input type="text"
                                   class="form-control" />

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mb-3">

                            <label class="form-label">
                                Email
                            </label>

                            <input type="email"
                                   class="form-control" />

                        </div>

                    </div>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Address
                    </label>

                    <textarea class="form-control"
                              rows="3"></textarea>

                </div>

                <div class="row">

                    <div class="col-md-6">

                        <label class="form-label">
                            City
                        </label>

                        <input type="text"
                               class="form-control" />

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Member Type
                        </label>

                        <select class="form-select">

                            <option>Regular</option>
                            <option>Silver</option>
                            <option>Gold</option>

                        </select>

                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button class="btn btn-primary">

                    Save Customer

                </button>

            </div>

        </div>

    </div>

</div>

<!-- EDIT CUSTOMER -->

<div class="modal fade"
     id="editCustomerModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Edit Customer
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <input class="form-control mb-3"
                       value="Hendi Dwi Purwanto" />

                <input class="form-control mb-3"
                       value="081234567890" />

                <input class="form-control mb-3"
                       value="hendi@mail.com" />

                <select class="form-select">

                    <option>Regular</option>
                    <option>Silver</option>
                    <option selected>Gold</option>

                </select>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button class="btn btn-primary">

                    Update Customer

                </button>

            </div>

        </div>

    </div>

</div>

<!-- DEACTIVATE CUSTOMER -->

<div class="modal fade"
     id="deactivateCustomerModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Deactivate Customer
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                Customer will be marked as inactive.

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button class="btn btn-danger">

                    Deactivate

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        new DataTable('#customersTable',
        {
            responsive: true,

            pageLength: 10,

            order: [[1, 'asc']],

            layout:
            {
                topStart:
                {
                    buttons:
                    [
                        {
                            extend: 'copy',
                            className: 'btn btn-secondary'
                        },
                        {
                            extend: 'excel',
                            className: 'btn btn-success'
                        },
                        {
                            extend: 'pdf',
                            className: 'btn btn-danger'
                        },
                        {
                            extend: 'print',
                            className: 'btn btn-primary'
                        }
                    ]
                }
            }
        });

    </script>
}