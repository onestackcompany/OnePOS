@{
    ViewData["Title"] = "Categories";
    ViewData["PageTitle"] = "Category Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card border-0 shadow-sm">

    <div class="card-header bg-white">

        <div class="d-flex justify-content-between align-items-center">

            <h5 class="mb-0">
                Category List
            </h5>

            <button class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addCategoryModal">

                <i class="bi bi-plus-circle me-1"></i>

                Add Category

            </button>

        </div>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table id="categoriesTable"
                   class="table table-striped table-hover align-middle">

                <thead>

                    <tr>

                        <th>Code</th>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Total Products</th>
                        <th>Status</th>
                        <th width="150">Action</th>

                    </tr>

                </thead>

                <tbody>

                    <tr>

                        <td>CAT001</td>
                        <td>Donut</td>
                        <td>All donut products</td>
                        <td>15</td>

                        <td>
                            <span class="badge bg-success">
                                Active
                            </span>
                        </td>

                        <td>

                            <button class="btn btn-sm btn-warning"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editCategoryModal">

                                <i class="bi bi-pencil-square"></i>

                            </button>

                            <button class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deactivateCategoryModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>CAT002</td>
                        <td>Drink</td>
                        <td>All beverage products</td>
                        <td>10</td>

                        <td>
                            <span class="badge bg-success">
                                Active
                            </span>
                        </td>

                        <td>

                            <button class="btn btn-sm btn-warning"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editCategoryModal">

                                <i class="bi bi-pencil-square"></i>

                            </button>

                            <button class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deactivateCategoryModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>CAT003</td>
                        <td>Snack</td>
                        <td>Snack products</td>
                        <td>8</td>

                        <td>
                            <span class="badge bg-success">
                                Active
                            </span>
                        </td>

                        <td>

                            <button class="btn btn-sm btn-warning"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editCategoryModal">

                                <i class="bi bi-pencil-square"></i>

                            </button>

                            <button class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deactivateCategoryModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>CAT004</td>
                        <td>Seasonal</td>
                        <td>Seasonal products</td>
                        <td>3</td>

                        <td>
                            <span class="badge bg-danger">
                                Inactive
                            </span>
                        </td>

                        <td>

                            <button class="btn btn-sm btn-warning"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editCategoryModal">

                                <i class="bi bi-pencil-square"></i>

                            </button>

                            <button class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deactivateCategoryModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- ADD CATEGORY -->

<div class="modal fade"
     id="addCategoryModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Add Category
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="mb-3">

                    <label class="form-label">
                        Category Code
                    </label>

                    <input type="text"
                           class="form-control"
                           placeholder="CAT005" />

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Category Name
                    </label>

                    <input type="text"
                           class="form-control"
                           placeholder="Bakery" />

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Description
                    </label>

                    <textarea class="form-control"
                              rows="3"></textarea>

                </div>

                <div class="mb-0">

                    <label class="form-label">
                        Status
                    </label>

                    <select class="form-select">

                        <option selected>
                            Active
                        </option>

                        <option>
                            Inactive
                        </option>

                    </select>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button class="btn btn-primary">

                    Save Category

                </button>

            </div>

        </div>

    </div>

</div>

<!-- EDIT CATEGORY -->

<div class="modal fade"
     id="editCategoryModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Edit Category
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="mb-3">

                    <label class="form-label">
                        Category Code
                    </label>

                    <input type="text"
                           class="form-control"
                           value="CAT001" />

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Category Name
                    </label>

                    <input type="text"
                           class="form-control"
                           value="Donut" />

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Description
                    </label>

                    <textarea class="form-control"
                              rows="3">All donut products</textarea>

                </div>

                <div>

                    <label class="form-label">
                        Status
                    </label>

                    <select class="form-select">

                        <option selected>
                            Active
                        </option>

                        <option>
                            Inactive
                        </option>

                    </select>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button class="btn btn-primary">

                    Update Category

                </button>

            </div>

        </div>

    </div>

</div>

<!-- DEACTIVATE CATEGORY -->

<div class="modal fade"
     id="deactivateCategoryModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Deactivate Category
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <p>

                    This category will be marked as inactive.

                </p>

                <div class="alert alert-warning mb-0">

                    Existing products will remain available.

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button class="btn btn-danger">

                    Deactivate

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        new DataTable('#categoriesTable',
        {
            responsive: true,

            pageLength: 10,

            order: [[1, 'asc']],

            layout:
            {
                topStart:
                {
                    buttons:
                    [
                        {
                            extend: 'copy',
                            className: 'btn btn-secondary'
                        },
                        {
                            extend: 'excel',
                            className: 'btn btn-success'
                        },
                        {
                            extend: 'pdf',
                            className: 'btn btn-danger'
                        },
                        {
                            extend: 'print',
                            className: 'btn btn-primary'
                        }
                    ]
                }
            }
        });

    </script>
}