@{
    ViewData["Title"] = "Settings";
    ViewData["PageTitle"] = "Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row g-4">

    <!-- USER MANAGEMENT -->

    <div class="col-md-4">

        <div class="card border-0 shadow-sm h-100">

            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">

                    <div>

                        <h5>
                            <i class="bi bi-people me-2"></i>
                            User Management
                        </h5>

                        <p class="text-muted mb-0">
                            Manage system users
                        </p>

                    </div>

                </div>

                <hr />

                <a asp-controller="Users"
                   asp-action="Index"
                   class="btn btn-primary">

                    Open

                </a>

            </div>

        </div>

    </div>

    <!-- ROLES -->

    <div class="col-md-4">

        <div class="card border-0 shadow-sm h-100">

            <div class="card-body">

                <h5>

                    <i class="bi bi-shield-lock me-2"></i>

                    Roles

                </h5>

                <p class="text-muted">
                    Role management
                </p>

                <span class="badge bg-warning text-dark">
                    Coming Soon
                </span>

            </div>

        </div>

    </div>

    <!-- PERMISSIONS -->

    <div class="col-md-4">

        <div class="card border-0 shadow-sm h-100">

            <div class="card-body">

                <h5>

                    <i class="bi bi-key me-2"></i>

                    Permissions

                </h5>

                <p class="text-muted">
                    Permission management
                </p>

                <span class="badge bg-warning text-dark">
                    Coming Soon
                </span>

            </div>

        </div>

    </div>

    <!-- COMPANY PROFILE -->

    <div class="col-md-4">

        <div class="card border-0 shadow-sm h-100">

            <div class="card-body">

                <h5>

                    <i class="bi bi-building me-2"></i>

                    Company Profile

                </h5>

                <p class="text-muted">
                    Company information
                </p>

                <span class="badge bg-warning text-dark">
                    Coming Soon
                </span>

            </div>

        </div>

    </div>

    <!-- TAX CONFIG -->

    <div class="col-md-4">

        <div class="card border-0 shadow-sm h-100">

            <div class="card-body">

                <h5>

                    <i class="bi bi-cash-stack me-2"></i>

                    Tax Configuration

                </h5>

                <p class="text-muted">
                    Tax settings
                </p>

                <span class="badge bg-warning text-dark">
                    Coming Soon
                </span>

            </div>

        </div>

    </div>

    <!-- AUDIT LOG -->

    <div class="col-md-4">

        <div class="card border-0 shadow-sm h-100">

            <div class="card-body">

                <h5>

                    <i class="bi bi-journal-text me-2"></i>

                    Audit Logs

                </h5>

                <p class="text-muted">
                    Activity history
                </p>

                <span class="badge bg-warning text-dark">
                    Coming Soon
                </span>

            </div>

        </div>

    </div>

</div>