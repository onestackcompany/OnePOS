@{
    ViewData["Title"] = "Sales";
    ViewData["PageTitle"] = "Sales POS";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">

    <!-- PRODUCT SECTION -->
    <div class="col-lg-8">

        <!-- FILTER -->
        <div class="card border-0 shadow-sm mb-3">

            <div class="card-body">

                <div class="row g-3">

                    <div class="col-md-5">

                        <label class="form-label">
                            Search Product
                        </label>

                        <input type="text"
                               class="form-control"
                               placeholder="Search product..." />

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">
                            Barcode
                        </label>

                        <input type="text"
                               class="form-control"
                               placeholder="Scan barcode..." />

                    </div>

                    <div class="col-md-3">

                        <label class="form-label">
                            Category
                        </label>

                        <select class="form-select">

                            <option>All</option>
                            <option>Donut</option>
                            <option>Drink</option>
                            <option>Snack</option>

                        </select>

                    </div>

                </div>

            </div>

        </div>

        <!-- PRODUCT GRID -->
        <div class="row g-3">

            @for (int i = 1; i <= 12; i++)
            {
                <div class="col-md-4">

                    <div class="card border-0 shadow-sm h-100">

                        <div class="card-body text-center">

                            <i class="bi bi-box-seam text-primary"
                               style="font-size:50px;">
                            </i>

                            <h6 class="mt-3">
                                Product @i
                            </h6>

                            <div class="text-muted mb-3">
                                Rp 25.000
                            </div>

                            <button class="btn btn-primary w-100">

                                <i class="bi bi-plus-circle me-1"></i>

                                Add To Cart

                            </button>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

    <!-- CART SECTION -->
    <div class="col-lg-4">

        <div class="card border-0 shadow-sm">

            <div class="card-header bg-white">

                <h5 class="mb-0">
                    Shopping Cart
                </h5>

            </div>

            <div class="card-body">

                <!-- CUSTOMER -->

                <div class="mb-3">

                    <label class="form-label">
                        Customer
                    </label>

                    <select class="form-select">

                        <option>
                            Walk In Customer
                        </option>

                        <option>
                            Hendi
                        </option>

                        <option>
                            Dida
                        </option>

                    </select>

                </div>

                <hr />

                <!-- CART ITEM 1 -->

                <div class="mb-3">

                    <div class="d-flex justify-content-between">

                        <div>

                            <strong>
                                Chocolate Donut
                            </strong>

                            <div class="small text-muted">

                                Rp 12.000

                            </div>

                        </div>

                        <button class="btn btn-sm btn-outline-danger">

                            <i class="bi bi-trash"></i>

                        </button>

                    </div>

                    <div class="d-flex align-items-center mt-2">

                        <button class="btn btn-outline-secondary btn-sm">
                            -
                        </button>

                        <span class="mx-3">
                            2
                        </span>

                        <button class="btn btn-outline-secondary btn-sm">
                            +
                        </button>

                    </div>

                </div>

                <hr />

                <!-- CART ITEM 2 -->

                <div class="mb-3">

                    <div class="d-flex justify-content-between">

                        <div>

                            <strong>
                                Ice Latte
                            </strong>

                            <div class="small text-muted">

                                Rp 18.000

                            </div>

                        </div>

                        <button class="btn btn-sm btn-outline-danger">

                            <i class="bi bi-trash"></i>

                        </button>

                    </div>

                    <div class="d-flex align-items-center mt-2">

                        <button class="btn btn-outline-secondary btn-sm">
                            -
                        </button>

                        <span class="mx-3">
                            1
                        </span>

                        <button class="btn btn-outline-secondary btn-sm">
                            +
                        </button>

                    </div>

                </div>

                <hr />

                <!-- DISCOUNT -->

                <div class="mb-3">

                    <label class="form-label">
                        Discount
                    </label>

                    <input type="number"
                           class="form-control"
                           value="0" />

                </div>

                <!-- TAX -->

                <div class="mb-3">

                    <label class="form-label">
                        Tax (%)
                    </label>

                    <input type="number"
                           class="form-control"
                           value="11" />

                </div>

                <hr />

                <!-- SUMMARY -->

                <div class="d-flex justify-content-between mb-2">

                    <span>
                        Subtotal
                    </span>

                    <strong>
                        Rp 42.000
                    </strong>

                </div>

                <div class="d-flex justify-content-between mb-2">

                    <span>
                        Discount
                    </span>

                    <strong>
                        Rp 0
                    </strong>

                </div>

                <div class="d-flex justify-content-between mb-2">

                    <span>
                        Tax
                    </span>

                    <strong>
                        Rp 4.620
                    </strong>

                </div>

                <hr />

                <div class="d-flex justify-content-between mb-4">

                    <h5>
                        Total
                    </h5>

                    <h5 class="text-primary">

                        Rp 46.620

                    </h5>

                </div>

                <!-- PAYMENT -->

                <div class="mb-3">

                    <label class="form-label">
                        Payment Method
                    </label>

                    <select class="form-select">

                        <option>
                            Cash
                        </option>

                        <option>
                            QRIS
                        </option>

                        <option>
                            Debit Card
                        </option>

                    </select>

                </div>

                <button class="btn btn-success btn-lg w-100"
                        data-bs-toggle="modal"
                        data-bs-target="#receiptModal">

                    <i class="bi bi-cash-coin me-2"></i>

                    Pay Now

                </button>

            </div>

        </div>

    </div>

</div>

<!-- RECEIPT MODAL -->

<div class="modal fade"
     id="receiptModal"
     tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Receipt Preview
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div id="receiptArea">

                    <div class="text-center">

                        <h4>
                            One Stack POS
                        </h4>

                        <small>
                            Pasuruan, East Java
                        </small>

                    </div>

                    <hr />

                    <div>
                        <strong>Invoice :</strong>
                        INV-20260620-001
                    </div>

                    <div>
                        <strong>Date :</strong>
                        20-Jun-2026
                    </div>

                    <div>
                        <strong>Customer :</strong>
                        Walk In Customer
                    </div>

                    <div>
                        <strong>Payment :</strong>
                        Cash
                    </div>

                    <hr />

                    <table class="table table-sm">

                        <thead>

                            <tr>

                                <th>Item</th>
                                <th>Qty</th>
                                <th class="text-end">
                                    Total
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr>

                                <td>
                                    Chocolate Donut
                                </td>

                                <td>
                                    2
                                </td>

                                <td class="text-end">
                                    24.000
                                </td>

                            </tr>

                            <tr>

                                <td>
                                    Ice Latte
                                </td>

                                <td>
                                    1
                                </td>

                                <td class="text-end">
                                    18.000
                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <hr />

                    <div class="d-flex justify-content-between">

                        <span>
                            Subtotal
                        </span>

                        <strong>
                            Rp 42.000
                        </strong>

                    </div>

                    <div class="d-flex justify-content-between">

                        <span>
                            Tax
                        </span>

                        <strong>
                            Rp 4.620
                        </strong>

                    </div>

                    <hr />

                    <div class="d-flex justify-content-between">

                        <h5>
                            Total
                        </h5>

                        <h5>
                            Rp 46.620
                        </h5>

                    </div>

                    <hr />

                    <div class="text-center">

                        Thank You For Your Purchase

                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Close

                </button>

                <button class="btn btn-primary"
                        onclick="window.print()">

                    <i class="bi bi-printer me-1"></i>

                    Print

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        console.log("Sales POS Loaded");

    </script>
}