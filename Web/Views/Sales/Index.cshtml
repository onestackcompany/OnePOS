@{
    ViewData["Title"] = "Sales";
    ViewData["PageTitle"] = "Sales Management";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var products = new[]
    {
        new { Id = 1, Name = "Chocolate Donut", Price = 12000 },
        new { Id = 2, Name = "Ice Latte", Price = 18000 },
        new { Id = 3, Name = "Americano", Price = 15000 },
        new { Id = 4, Name = "Matcha Donut", Price = 13000 },
        new { Id = 5, Name = "Vanilla Donut", Price = 12000 },
        new { Id = 6, Name = "Cappuccino", Price = 22000 }
    };
}

<div class="row">
    <div class="col-lg-8">
        <div class="row g-3">
            @foreach (var item in products)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-body text-center">
                            <h6>@item.Name</h6>
                            <div class="mb-2">Rp @item.Price.ToString("N0")</div>
                            <button class="btn btn-primary w-100 btn-add-cart"
                                    data-id="@item.Id"
                                    data-name="@item.Name"
                                    data-price="@item.Price">
                                Add To Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header">Shopping Cart</div>
            <div class="card-body">

               

                <div id="cartItems">
                    <div class="text-center text-muted">Cart Empty</div>
                </div>

                <hr>

                <div class="d-flex justify-content-between">
                    <span>Subtotal</span>
                    <strong id="subtotal">Rp 0</strong>
                </div>

                <div class="d-flex justify-content-between">
                    <span>Tax 11%</span>
                    <strong id="tax">Rp 0</strong>
                </div>

                <div class="d-flex justify-content-between mb-3">
                    <span>Total</span>
                    <strong id="grandTotal">Rp 0</strong>
                </div>
                <div class="text-center mb-1">Payment Method</div>
                <select id="paymentMethod" class="form-select mb-3">
                    <option>Cash</option>
                    <option>QRIS</option>
                    <option>Debit Card</option>
                </select>

                <button id="btnPayNow" class="btn btn-success w-100">
                    Pay Now
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="receiptModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>Receipt</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="receiptContent"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cart = JSON.parse(sessionStorage.getItem('pos_cart') || '[]');

        function rupiah(v){
            return 'Rp ' + Number(v).toLocaleString('id-ID');
        }

        function save(){
            sessionStorage.setItem('pos_cart', JSON.stringify(cart));
        }

        function render(){
            let html='';
            let subtotal=0;

            cart.forEach(x=>{
                subtotal += x.price * x.qty;

                html += `
                <div class="border-bottom mb-2 pb-2">
                    <div class="d-flex justify-content-between">
                        <strong>${x.name}</strong>
                        <button class="btn btn-sm btn-danger remove" data-id="${x.id}">x</button>
                    </div>
                    <div>
                        <button class="btn btn-sm btn-secondary minus" data-id="${x.id}">-</button>
                        <span class="mx-2">${x.qty}</span>
                        <button class="btn btn-sm btn-secondary plus" data-id="${x.id}">+</button>
                    </div>
                </div>`;
            });

            if(cart.length===0)
                html='<div class="text-center text-muted">Cart Empty</div>';

            $('#cartItems').html(html);

            let tax=subtotal*0.11;
            let total=subtotal+tax;

            $('#subtotal').text(rupiah(subtotal));
            $('#tax').text(rupiah(tax));
            $('#grandTotal').text(rupiah(total));

            save();
        }

        $(document).on('click','.btn-add-cart',function(){
            let id=$(this).data('id');
            let item=cart.find(x=>x.id==id);

            if(item) item.qty++;
            else{
                cart.push({
                    id:id,
                    name:$(this).data('name'),
                    price:parseInt($(this).data('price')),
                    qty:1
                });
            }

            render();
        });

        $(document).on('click','.plus',function(){
            let item=cart.find(x=>x.id==$(this).data('id'));
            item.qty++;
            render();
        });

        $(document).on('click','.minus',function(){
            let item=cart.find(x=>x.id==$(this).data('id'));
            item.qty--;
            if(item.qty<=0)
                cart=cart.filter(x=>x.id!=item.id);
            render();
        });

        $(document).on('click','.remove',function(){
            let id=$(this).data('id');
            cart=cart.filter(x=>x.id!=id);
            render();
        });

        $('#btnPayNow').click(function(){

            if(cart.length===0){
                alert('Cart Empty');
                return;
            }

            let subtotal=cart.reduce((a,b)=>a+(b.price*b.qty),0);
            let tax=subtotal*0.11;
            let total=subtotal+tax;

            let html='';
            html += '<p><strong>Payment :</strong> '+$('#paymentMethod').val()+'</p><hr>';

            cart.forEach(x=>{
                html += '<div>'+x.name+' x '+x.qty+'</div>';
            });

            html += '<hr><strong>Total : '+rupiah(total)+'</strong>';

            $('#receiptContent').html(html);

            new bootstrap.Modal(document.getElementById('receiptModal')).show();
        });

        $('#receiptModal').on('hidden.bs.modal',function(){
            cart=[];
            render();
        });

        $(function(){
            render();
        });
    </script>
}
