                                    data-bs-target="#deactivateModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>PRD005</td>
                        <td>Vanilla Donut</td>
                        <td>Donut</td>
                        <td>899100005</td>
