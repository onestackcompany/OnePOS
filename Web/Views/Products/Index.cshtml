                        <td>
                            <span class="badge bg-success">
                                75
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-success">
                                Active
                            </span>
                        </td>

                        <td>

                            <a href="/Products/Edit/2"
                               class="btn btn-sm btn-warning">

                                <i class="bi bi-pencil-square"></i>

                            </a>

                            <button class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deactivateModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>PRD003</td>
                        <td>Ice Latte</td>
                        <td>Drink</td>
                        <td>899100003</td>
                        <td>Rp 12.000</td>
                        <td>Rp 18.000</td>

                        <td>
                            <span class="badge bg-success">
                                50
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-success">
                                Active
                            </span>
                        </td>

                        <td>

                            <a href="/Products/Edit/3"
                               class="btn btn-sm btn-warning">

                                <i class="bi bi-pencil-square"></i>

                            </a>

                            <button class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deactivateModal">

                                <i class="bi bi-slash-circle"></i>

                            </button>

                        </td>

                    </tr>

                    <tr>

                        <td>PRD004</td>
