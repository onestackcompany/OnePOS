@{
    ViewData["Title"] = "Inventory";
    ViewData["PageTitle"] = "Inventory Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card border-0 shadow-sm">

    <div class="card-header bg-white">

        <div class="d-flex justify-content-between align-items-center">

            <h5 class="mb-0">
                Inventory Management
            </h5>

            <div>

                <button class="btn btn-success me-2"
                        data-bs-toggle="modal"
                        data-bs-target="#stockInModal">

                    <i class="bi bi-box-arrow-in-down me-1"></i>
                    Stock In

                </button>

                <button class="btn btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#stockOutModal">

                    <i class="bi bi-box-arrow-up me-1"></i>
                    Stock Out

                </button>

            </div>

        </div>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table id="inventoryTable"
                   class="table table-striped table-hover align-middle">

                <thead>

                    <tr>

                        <th>Product Code</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Current Stock</th>
                        <th>Minimum Stock</th>
                        <th>Status</th>

                    </tr>

                </thead>

                <tbody>

                    <tr>

                        <td>PRD001</td>
                        <td>Chocolate Donut</td>
                        <td>Donut</td>
                        <td>100</td>
                        <td>10</td>

                        <td>
                            <span class="badge bg-success">
                                Normal
                            </span>
                        </td>

                    </tr>

                    <tr>

                        <td>PRD002</td>
                        <td>Ice Latte</td>
                        <td>Drink</td>
                        <td>50</td>
                        <td>10</td>

                        <td>
                            <span class="badge bg-success">
                                Normal
                            </span>
                        </td>

                    </tr>

                    <tr>

                        <td>PRD003</td>
                        <td>Vanilla Donut</td>
                        <td>Donut</td>
                        <td>3</td>
                        <td>10</td>

                        <td>
                            <span class="badge bg-danger">
                                Low Stock
                            </span>
                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>

<br />

<div class="card border-0 shadow-sm">

    <div class="card-header bg-white">

        <h5 class="mb-0">
            Stock Movement History
        </h5>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table id="stockHistoryTable"
                   class="table table-striped table-hover">

                <thead>

                    <tr>

                        <th>Date</th>
                        <th>Product</th>
                        <th>Transaction Type</th>
                        <th>Qty</th>
                        <th>Reference</th>
                        <th>User</th>

                    </tr>

                </thead>

                <tbody>

                    <tr>

                        <td>20-Jun-2026</td>
                        <td>Chocolate Donut</td>
                        <td>
                            <span class="badge bg-success">
                                Stock In
                            </span>
                        </td>
                        <td>50</td>
                        <td>PO-001</td>
                        <td>Admin</td>

                    </tr>

                    <tr>

                        <td>20-Jun-2026</td>
                        <td>Ice Latte</td>
                        <td>
                            <span class="badge bg-danger">
                                Stock Out
                            </span>
                        </td>
                        <td>10</td>
                        <td>INV-001</td>
                        <td>Cashier</td>

                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- STOCK IN MODAL -->

<div class="modal fade"
     id="stockInModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Stock In
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="mb-3">

                    <label class="form-label">
                        Product
                    </label>

                    <select class="form-select">

                        <option>Chocolate Donut</option>
                        <option>Ice Latte</option>

                    </select>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Quantity
                    </label>

                    <input type="number"
                           class="form-control">

                </div>

                <div>

                    <label class="form-label">
                        Notes
                    </label>

                    <textarea class="form-control"
                              rows="3"></textarea>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button class="btn btn-success">

                    Save

                </button>

            </div>

        </div>

    </div>

</div>

<!-- STOCK OUT MODAL -->

<div class="modal fade"
     id="stockOutModal"
     tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Stock Out
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="mb-3">

                    <label class="form-label">
                        Product
                    </label>

                    <select class="form-select">

                        <option>Chocolate Donut</option>
                        <option>Ice Latte</option>

                    </select>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Quantity
                    </label>

                    <input type="number"
                           class="form-control">

                </div>

                <div>

                    <label class="form-label">
                        Notes
                    </label>

                    <textarea class="form-control"
                              rows="3"></textarea>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button class="btn btn-danger">

                    Save

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        new DataTable('#inventoryTable',
        {
            responsive: true,
            pageLength: 10,
            order: [[1, 'asc']]
        });

        new DataTable('#stockHistoryTable',
        {
            responsive: true,
            pageLength: 10,
            order: [[0, 'desc']]
        });

    </script>
}